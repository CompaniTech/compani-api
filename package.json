{
  "name": "alenvi-api",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test:unit": "NODE_ENV=test mocha --timeout 999999 --colors --exit tests/unit/*/*",
    "test:integration": "NODE_ENV=test mocha --timeout 999999 --colors --exit --file server.js tests/integration/helpers/initializeDB tests/integration/*",
    "test:tag": "NODE_ENV=test mocha --timeout 999999 --colors --recursive --exit --grep '#tag' --file server.js tests/integration/helpers/initializeDB tests/*",
    "test:seeds": "NODE_ENV=test mocha --timeout 999999 --colors --recursive --exit --file server.js tests/integration/helpers/initializeDB tests/integration/seed/seedsVerification.test.js",
    "test": "NODE_ENV=test mocha --timeout 999999 --colors --recursive --exit --file server.js tests/integration/helpers/initializeDB tests/*",
    "test-watch": "nodemon --exec 'npm test'",
    "debug": "nodemon --inspect",
    "lint": "eslint .",
    "prestart": "echo $MAX_OLD_SPACE_SIZE",
    "start": "node --optimize_for_size --max_old_space_size=$MAX_OLD_SPACE_SIZE --gc_interval=100 server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jctrebalag/alenvi-api-migration.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jctrebalag/alenvi-api-migration/issues"
  },
  "homepage": "https://github.com/jctrebalag/alenvi-api-migration#readme",
  "engines": {
    "node": "22.20.0"
  },
  "dependencies": {
    "@google-cloud/storage": "~7.19.0",
    "@googleapis/drive": "~20.1.0",
    "@googleapis/sheets": "~13.0.1",
    "@hapi/boom": "~10.0.1",
    "@hapi/good": "~9.0.1",
    "@hapi/good-console": "~9.0.1",
    "@hapi/good-squeeze": "~6.0.0",
    "@hapi/hapi": "~21.4.7",
    "@hapi/inert": "~7.1.0",
    "axios": "~1.13.6",
    "bcryptjs": "~3.0.3",
    "bignumber.js": "~10.0.2",
    "cron": "~4.4.0",
    "date-holidays": "~3.26.9",
    "docxtemplater": "~3.68.3",
    "dotenv": "~17.3.1",
    "flat": "~5.0.2",
    "form-data": "~4.0.5",
    "hapi-auth-jwt2": "~11.0.0",
    "hapi-sentry": "~4.0.0",
    "intl": "~1.2.5",
